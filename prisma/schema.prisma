generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MarketplaceSource {
  EBAY
  FACEBOOK
  MERCARI
  OTHER
}

enum SearchStrategyMode {
  FLIP
  BUY_AND_HOLD
  ARBITRAGE
  CLEARANCE
  CUSTOM
}

enum RiskTolerance {
  LOW
  MEDIUM
  HIGH
}

enum SearchProfileStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ListingType {
  AUCTION
  FIXED_PRICE
  CLASSIFIED
  UNKNOWN
}

enum CompletenessLevel {
  COMPLETE
  MOSTLY_COMPLETE
  PARTIAL
  UNKNOWN
}

enum DefectState {
  NONE
  COSMETIC
  FUNCTIONAL
  PARTS_ONLY
  UNKNOWN
}

enum LiquidityBand {
  LOW
  MEDIUM
  HIGH
}

enum ListingState {
  STANDARD
  INCOMPLETE
  ACCESSORY_ONLY
  PARTS_REPAIR
  LOT
  UNKNOWN
}

enum SpecialItemType {
  NONE
  ACCESSORY
  BUNDLE
  DISPLAY_UNIT
  OPEN_BOX
  PARTS_REPAIR
  LOT
  COLLECTIBLE
  UNKNOWN
}

enum VisibilityLevel {
  HIDDEN
  LOW
  MEDIUM
  HIGH
}

enum EvaluationDecision {
  SKIP
  WATCH
  REVIEW
  NEGOTIATE
  BUY
}

enum OfferStrategy {
  NONE
  AGGRESSIVE
  BALANCED
  CONSERVATIVE
}

enum AlertType {
  NEW_HIGH_SCORE_OPPORTUNITY
  PRICE_DROPPED
  DECISION_UPGRADED_TO_BUY_NOW
  DECISION_UPGRADED_TO_MAKE_OFFER
  NEW_LISTING_MATCHED_PROFILE
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id         String          @id @default(cuid())
  email      String          @unique
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  profiles   SearchProfile[]
}

model SearchProfile {
  id                      String               @id @default(cuid())
  userId                  String
  name                    String
  strategyMode            SearchStrategyMode
  riskTolerance           RiskTolerance
  strictMode              Boolean              @default(false)
  includePartsRepairs     Boolean              @default(false)
  includeIncompleteItems  Boolean              @default(false)
  includeAccessories      Boolean              @default(true)
  showLowConfidenceItems  Boolean              @default(false)
  minScore                Decimal              @db.Decimal(6, 2)
  minConfidence           Decimal              @db.Decimal(5, 4)
  maxBudget               Decimal?             @db.Decimal(12, 2)
  minResaleMarginPct      Decimal?             @db.Decimal(6, 2)
  searchTerms             String[]
  excludedTerms           String[]
  categoryHint            String?
  status                  SearchProfileStatus  @default(ACTIVE)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  user                    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  evaluations             ListingEvaluation[]
  alerts                  Alert[]

  @@index([userId, status])
  @@unique([userId, name])
}

model ListingRaw {
  id                     String              @id @default(cuid())
  source                 MarketplaceSource
  externalItemId         String
  title                  String
  description            String?
  url                    String
  itemPrice              Decimal?            @db.Decimal(12, 2)
  shippingPrice          Decimal?            @db.Decimal(12, 2)
  currency               String              @db.VarChar(3)
  listingType            ListingType         @default(UNKNOWN)
  bestOfferAvailable     Boolean             @default(false)
  sellerFeedbackPercent  Decimal?            @db.Decimal(5, 2)
  sellerFeedbackCount    Int?
  photoCount             Int?
  endTime                DateTime?
  createdAt              DateTime            @default(now())
  fetchedAt              DateTime
  rawJson                Json
  normalized             ListingNormalized?
  evaluations            ListingEvaluation[]
  alerts                 Alert[]

  @@unique([source, externalItemId])
  @@index([source, fetchedAt])
}

model ListingNormalized {
  id                       String             @id @default(cuid())
  listingRawId             String             @unique
  brand                    String?
  model                    String?
  variant                  String?
  size                     String?
  color                    String?
  storage                  String?
  lotSize                  Int?
  completeness             CompletenessLevel  @default(UNKNOWN)
  defectState              DefectState        @default(UNKNOWN)
  accessoryFlag            Boolean            @default(false)
  normalizationConfidence  Decimal            @db.Decimal(5, 4)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  listingRaw               ListingRaw         @relation(fields: [listingRawId], references: [id], onDelete: Cascade)

  @@index([brand, model, variant])
}

model MarketSnapshot {
  id                  String              @id @default(cuid())
  comparableGroupKey  String
  sampleSize          Int
  medianPrice         Decimal             @db.Decimal(12, 2)
  p25Price            Decimal?            @db.Decimal(12, 2)
  p10Price            Decimal?            @db.Decimal(12, 2)
  stdDev              Decimal?            @db.Decimal(12, 2)
  liquidityBand       LiquidityBand
  snapshotAt          DateTime
  evaluations         ListingEvaluation[]

  @@index([comparableGroupKey, snapshotAt])
}

model ListingEvaluation {
  id                        String               @id @default(cuid())
  listingRawId              String
  searchProfileId           String
  marketSnapshotId          String?
  listingState              ListingState
  specialItemType           SpecialItemType      @default(NONE)
  comparableMatchConfidence Decimal?             @db.Decimal(5, 4)
  profileCompatibility      Decimal?             @db.Decimal(5, 4)
  visibilityLevel           VisibilityLevel
  decision                  EvaluationDecision
  decisionConfidence        Decimal?             @db.Decimal(5, 4)
  priceOpportunityScore     Decimal?             @db.Decimal(6, 2)
  listingAlphaScore         Decimal?             @db.Decimal(6, 2)
  sellerScore               Decimal?             @db.Decimal(6, 2)
  liquidityScore            Decimal?             @db.Decimal(6, 2)
  timingScore               Decimal?             @db.Decimal(6, 2)
  completenessFitScore      Decimal?             @db.Decimal(6, 2)
  riskPenalty               Decimal?             @db.Decimal(6, 2)
  confidencePenalty         Decimal?             @db.Decimal(6, 2)
  rawScore                  Decimal?             @db.Decimal(6, 2)
  uiScore                   Decimal?             @db.Decimal(6, 2)
  driversPositiveJson       Json?
  driversNegativeJson       Json?
  offerStrategy             OfferStrategy        @default(NONE)
  anchorOffer               Decimal?             @db.Decimal(12, 2)
  recommendedOffer          Decimal?             @db.Decimal(12, 2)
  walkAwayPrice             Decimal?             @db.Decimal(12, 2)
  evaluationJson            Json?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt
  listingRaw                ListingRaw           @relation(fields: [listingRawId], references: [id], onDelete: Cascade)
  searchProfile             SearchProfile        @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)
  marketSnapshot            MarketSnapshot?      @relation(fields: [marketSnapshotId], references: [id], onDelete: SetNull)
  alerts                    Alert[]

  @@unique([listingRawId, searchProfileId])
  @@index([searchProfileId, visibilityLevel, decision])
  @@index([listingRawId, visibilityLevel])
  @@index([marketSnapshotId])
}

model Alert {
  id                  String             @id @default(cuid())
  listingRawId        String
  searchProfileId     String
  listingEvaluationId String?
  alertType           AlertType
  severity            AlertSeverity
  dedupeKey           String             @unique
  title               String
  message             String
  metadataJson        Json?
  createdAt           DateTime           @default(now())
  readAt              DateTime?
  dismissedAt         DateTime?
  listingRaw          ListingRaw         @relation(fields: [listingRawId], references: [id], onDelete: Cascade)
  searchProfile       SearchProfile      @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)
  listingEvaluation   ListingEvaluation? @relation(fields: [listingEvaluationId], references: [id], onDelete: SetNull)

  @@index([searchProfileId, createdAt])
  @@index([listingRawId, createdAt])
  @@index([listingEvaluationId])
  @@index([createdAt])
}
